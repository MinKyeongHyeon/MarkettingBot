# Environment variable examples for MarkettingBot
# Copy to `.env` or set in your deployment environment (Vercel/Render/pm2)

## Server (apps/server)
# Public API key that server expects for requests from clients
PUBLIC_API_KEY=your_public_api_key_here

# Ollama settings (if using local Ollama)
OLLAMA_BASE=http://localhost:11434
OLLAMA_MODEL=exaone3.5

# CORS allowed origins (comma separated). If unset, all origins allowed.
# Example: CORS_ORIGIN=http://localhost:3000,https://example.com
CORS_ORIGIN=

# Server port (production default is 3001)
PORT=3001

## Web (apps/web)
# Base URL of the backend API (used by client requests)
NEXT_PUBLIC_API_BASE=http://localhost:3001

# Public API key that the client will send to the server (non-secret).
# NOTE: Client env var must start with `NEXT_PUBLIC_` so it is exposed to the browser.
# The server validates against `PUBLIC_API_KEY` (server-side env). Keep values in
# deployment platform: set `PUBLIC_API_KEY` on the server and `NEXT_PUBLIC_PUBLIC_API_KEY`
# on the web app to the same public token.
NEXT_PUBLIC_PUBLIC_API_KEY=your_public_api_key_here

## Optional / Advanced (for Vercel or tunnel setups)
# If deploying to Vercel (or other platform) and proxying Ollama through an
# authenticated tunnel, configure the following:
# VERCEL_API_KEY: shared key that clients include as `x-api-key` when calling the
# Edge route `/api/ollama`. Vercel middleware checks this header.
VERCEL_API_KEY=

# If you forward requests from Vercel to your local Ollama via a tunnel, set one of:
OLLAMA_TUNNEL_URL=            # e.g. https://abcd.ngrok-free.app (preferred when tunneling)
OLLAMA_BASE=http://localhost:11434
OLLAMA_MODEL=exaone3.5
OLLAMA_INTERNAL_TOKEN=        # optional internal bearer token used between Vercel and your local proxy

## Deployment / PM2
# Example: values used by PM2 ecosystem (optional)
NODE_ENV=production
